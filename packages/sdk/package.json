{
  "name": "hashion",
  "version": "0.0.11",
  "description": "Browser file hashing SDK with MD5, SHA, progress reporting, cancellation, and Web Worker support.",
  "keywords": [
    "web",
    "browser",
    "client",
    "file",
    "file-hash",
    "browser-hash",
    "hash",
    "md5",
    "sha",
    "sha-1",
    "sha-256",
    "sha-384",
    "sha-512",
    "spark-md5",
    "web-worker",
    "inline-worker",
    "cancellable",
    "async",
    "callback",
    "progress",
    "promise",
    "typescript",
    "vite"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "moyuderen",
  "homepage": "https://moyuderen.github.io/hashion",
  "repository": {
    "type": "git",
    "url": "https://github.com/moyuderen/hashion"
  },
  "bugs": {
    "url": "https://github.com/moyuderen/hashion/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./sha": {
      "types": "./dist/sha.d.ts",
      "import": "./dist/sha.js",
      "default": "./dist/sha.js"
    },
    "./spark": {
      "types": "./dist/spark.d.ts",
      "import": "./dist/spark.js",
      "default": "./dist/spark.js"
    },
    "./sparkWorker": {
      "types": "./dist/sparkWorker.d.ts",
      "import": "./dist/sparkWorker.js",
      "default": "./dist/sparkWorker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate": "pnpm typecheck && pnpm test:run",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/spark-md5": "^3.0.5",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.8"
  }
}
