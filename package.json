{
  "name": "hashion",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm dev:sdk",
    "dev:sdk": "pnpm --filter hashion dev",
    "dev:docs": "pnpm --filter docs docs:dev",
    "build": "pnpm build:sdk",
    "build:sdk": "pnpm --filter hashion build",
    "build:docs": "pnpm --filter docs docs:build",
    "build:all": "pnpm build:sdk && pnpm build:docs",
    "preview:sdk": "pnpm --filter hashion preview",
    "preview:docs": "pnpm --filter docs docs:preview",
    "typecheck": "pnpm --filter hashion exec tsc --noEmit",
    "clean": "pnpm clean:sdk && pnpm clean:docs",
    "clean:sdk": "rm -rf packages/sdk/dist",
    "clean:docs": "rm -rf docs/.vitepress/dist",
    "change:alpha": "pnpm changeset pre enter alpha",
    "change:beta": "pnpm changeset pre enter beta",
    "change:rc": "pnpm changeset pre enter rc",
    "change:stable": "pnpm changeset pre exit",
    "change": "pnpm changeset",
    "change-version": "pnpm changeset version",
    "release:check": "pnpm build:all",
    "publish:dry": "pnpm release:check && pnpm --filter hashion publish --dry-run",
    "publish:npm": "pnpm release:check && pnpm --filter hashion publish"
  },
  "author": "moyuderen",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.4"
  }
}
